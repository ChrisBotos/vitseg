{
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash",
      "WebFetch",
      "WebSearch",
      "Task",
      "TodoWrite",
      "Skill",
      "SlashCommand",
      "BashOutput",
      "KillBash",
      "Bash(pip install*:*)"
    ],
    "ask": [],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(rm *:*)",
      "Bash(rm /*:*)",
      "Bash(rm /:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git revert --no-edit:*)",
      "Bash(mkfs*:*)",
      "Bash(fdisk*:*)",
      "Bash(parted*:*)",
      "Bash(dd if=*:*)",
      "Bash(dd of=*:*)",
      "Bash(chown -R /:*)",
      "Bash(chmod -R 000 /:*)",
      "Bash(chmod -R 777 /:*)",
      "Bash(shutdown*:*)",
      "Bash(reboot*:*)",
      "Bash(poweroff*:*)"
    ]
  }
}
